if ! command -v nix_direnv_version >/dev/null 2>&1; then
  echo "sabiql: nix-direnv 3.1 or newer is required for direnv; use 'nix develop' instead" >&2
  return 1
fi

nix_direnv_version 3.1

cleanup_interrupted_profiles() {
  local profile profile_name pid
  for profile in .direnv/flake-tmp-profile.*; do
    [[ -e "$profile" || -L "$profile" ]] || continue
    profile_name=${profile##*/}
    pid=${profile_name#flake-tmp-profile.}
    pid=${pid%%.*}
    if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
      continue
    fi
    rm -f -- "$profile"
  done
}

cleanup_interrupted_profiles
use flake .
